# Exercise Library — cPanel/Apache performance config

# ---- Block directory listing (no bulk folder scraping) ----
Options -Indexes

# ---- GZIP compression ----
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json image/svg+xml
</IfModule>

# ---- Browser caching ----
<IfModule mod_expires.c>
  ExpiresActive On
  # Media never changes -> cache 1 year
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif  "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 month"
  # Static assets -> 1 month
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  # Data -> 1 day (so updates propagate)
  ExpiresByType application/json "access plus 1 day"
  # HTML -> revalidate
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(jpg|jpeg|gif|css|js)$">
    Header set Cache-Control "public, max-age=2592000, immutable"
  </FilesMatch>
  Header set X-Content-Type-Options "nosniff"
</IfModule>

# ---- Correct MIME types ----
<IfModule mod_mime.c>
  AddType application/json .json
  AddType image/gif .gif
</IfModule>

# Default document
DirectoryIndex index.html

# Pretty 404 -> back to library
ErrorDocument 404 /index.html
